---
import Rect from "./Rect.astro";

const {
  width = 100,
  height = 100,
  stroke = "black",
  outlineStrokeWidth = 4,
  inlineStrokeWidth = 4,
  fill = "none",
  ...rest
} = Astro.props;
---

<Rect width={width} height={height} stroke={stroke} fill={fill} strokeWidth={outlineStrokeWidth} {...rest}>
  <line
    x1="50"
    y1="30"
    x2="50"
    y2="45"
    stroke={stroke}
    stroke-width={inlineStrokeWidth}></line>
  <line
    x1="50"
    y1="55"
    x2="50"
    y2="70"
    stroke={stroke}
    stroke-width={inlineStrokeWidth}></line>
  <line
    x1="70"
    y1="50"
    x2="100"
    y2="50"
    stroke={stroke}
    stroke-width={inlineStrokeWidth}></line>
</Rect>
