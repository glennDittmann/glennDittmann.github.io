---
const {
  width = 100,
  height = 100,
  stroke = "black",
  strokeWidth = 4,
  fill = "none",
  ...rest
} = Astro.props;
---

<svg width={width} height={height} viewBox="0 0 100 100" {...rest}>
  <rect
    x="0"
    y="0"
    width="100"
    height="100"
    fill={fill}
    stroke={stroke}
    stroke-width={strokeWidth}
  >
  </rect>
  <slot />
</svg>

<style>
  svg {
    /* set this the svg container does not get clipped (would result in round corners and thind top/bottom edges) */
    overflow: visible;
  }
</style>