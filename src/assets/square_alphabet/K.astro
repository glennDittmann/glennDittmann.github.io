---
const {
  width = 100,
  height = 100,
  stroke = "black",
  outlineStrokeWidth = 4,
  inlineStrokeWidth = 4,
  fill = "none",
  rightHoleStroke = "none",
  rightHoleFill = "none",
  ...rest
} = Astro.props;
---

<svg width={width} height={height} viewBox="0 0 100 100" {...rest}>
  <polygon
    points="
      0,0
      0,100
      100,100
      100,60
      70,50
      100,40
      100,0
    "
    stroke={stroke}
    stroke-width={outlineStrokeWidth}
    fill={fill}></polygon>
  <line
    x1="50"
    y1="0"
    x2="50"
    y2="40"
    stroke={stroke}
    stroke-width={inlineStrokeWidth}></line>
  <line
    x1="50"
    y1="100"
    x2="50"
    y2="60"
    stroke={stroke}
    stroke-width={inlineStrokeWidth}></line>
    <!-- optional: draw an triangle that fills the K point right hole -->
    <!-- use if, e.g. when fill is none, and there is a background color set from a rectular container -->
    <!-- this way th ebckground color does not bleed out of the K point right hole -->
    <polygon
      points="
        100,60
        70,50
        100,40
        100,60
      "
      fill={rightHoleFill}
      stroke={rightHoleStroke}
      stroke-width={outlineStrokeWidth}
    />
</svg>

<style>
  svg {
    overflow: visible;
  }
</style>