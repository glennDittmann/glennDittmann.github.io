---
import Rect from "./Rect.astro";

const {
  width = 100,
  height = 100,
  stroke = "black",
  outlineStrokeWidth = 4,
  inlineStrokeWidth = 4,
  fill = "none",
  ...rest
} = Astro.props;
---

<Rect width={width} height={height} stroke={stroke} fill={fill} strokeWidth={outlineStrokeWidth} {...rest}>
  <line
    x1="30"
    y1="40"
    x2="100"
    y2="40"
    stroke={stroke}
    stroke-width={inlineStrokeWidth}></line>
  <line
    x1="0"
    y1="60"
    x2="70"
    y2="60"
    stroke={stroke}
    stroke-width={inlineStrokeWidth}></line>
</Rect>
